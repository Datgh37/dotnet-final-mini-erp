@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Quản lý Thương hiệu</h2>
    <button class="btn btn-primary" data-coreui-toggle="modal" data-coreui-target="#BrandModal">
        Thêm mới
    </button>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">ID</th>
                        <th>Tên thương hiệu</th>
                        <th>Mô tả</th>
                        <th class="text-end pe-4">Thao tác</th>
                    </tr>
                </thead>
                <tbody id="brandTable"></tbody>
            </table>
        </div>
    </div>
</div>

<!-- Brand Detail Modal -->
<div class="modal fade" id="BrandDetailModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header border-bottom">
                <h5 class="modal-title">Chi tiết thương hiệu</h5>
                <button type="button" class="btn-close" data-coreui-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-4">
                    <label class="text-body-secondary small d-block text-uppercase mb-1">Tên thương hiệu</label>
                    <h3 id="detailBrandName" class="text-primary fw-bold"></h3>
                </div>
                <div class="mb-3">
                    <label class="text-body-secondary small d-block text-uppercase mb-1">Mô tả</label>
                    <p id="detailBrandDescription" class="p-3 rounded border text-body"></p>
                </div>
                <div class="text-body-secondary small">ID hệ thống: <span id="detailBrandId"></span></div>
            </div>
            <div class="modal-footer bg-body-tertiary">
                <button type="button" class="btn btn-secondary" data-coreui-dismiss="modal">Đóng</button>
                <button type="button" class="btn btn-info text-white" id="btnEditBrandFromDetail">Sửa</button>
            </div>
        </div>
    </div>
</div>

<!-- Brand Modal -->
<div class="modal fade" id="BrandModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <form id="brandForm" class="modal-content needs-validation" novalidate>
            <div class="modal-header">
                <h5 class="modal-title" id="BrandModalLabel">Thêm thương hiệu mới</h5>
                <button type="button" class="btn-close" data-coreui-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="editBrandId">
                <div class="mb-3">
                    <label class="form-label">Tên thương hiệu <span class="text-danger">*</span></label>
                    <input type="text" class="form-control" id="brandName" required>
                    <div class="invalid-feedback">Tên thương hiệu là bắt buộc.</div>
                </div>
                <div class="mb-3">
                    <label class="form-label">Mô tả</label>
                    <textarea class="form-control" id="brandDescription" rows="3"></textarea>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-coreui-dismiss="modal">Hủy</button>
                <button type="submit" class="btn btn-primary">Lưu</button>
            </div>
        </form>
    </div>
</div>

<script>
    async function loadBrands() {
        try {
            const response = await fetch(`${API_BASE}/Brands`);
            if (!response.ok) return;
            const brands = await response.json();

            window.renderTable('brandTable', brands, b => `
                <tr>
                    <td class="ps-4 text-body-secondary">${b.id}</td>
                    <td><span class="fw-semibold">${b.name}</span></td>
                    <td class="text-body-secondary">${b.description || '-'}</td>
                    <td class="text-end pe-4">
                        <div class="btn-group">
                            <button class="btn btn-sm btn-primary" onclick="viewBrandDetail(${b.id})" title="Xem chi tiết">
                                <i class="cil-eye"></i> <span class="d-none d-lg-inline">Xem</span>
                            </button>
                            <button class="btn btn-sm btn-info text-white" onclick="editBrand(${b.id}, '${b.name}', '${b.description || ''}')" title="Sửa">
                                <i class="cil-pencil"></i> <span class="d-none d-lg-inline">Sửa</span>
                            </button>
                            <button class="btn btn-sm btn-danger text-white" onclick="deleteBrand(${b.id})" title="Xóa">
                                <i class="cil-trash"></i>
                            </button>
                        </div>
                    </td>
                </tr>
            `);
        } catch (e) { console.error(e); }
    }

    async function viewBrandDetail(id) {
        try {
            const response = await fetch(`${API_BASE}/Brands/${id}`);
            const b = await response.json();
            
            document.getElementById('detailBrandName').innerText = b.name;
            document.getElementById('detailBrandDescription').innerText = b.description || 'Không có mô tả.';
            document.getElementById('detailBrandId').innerText = b.id;
            
            document.getElementById('btnEditBrandFromDetail').onclick = () => {
                coreui.Modal.getInstance(document.getElementById('BrandDetailModal')).hide();
                editBrand(b.id, b.name, b.description || '');
            };
            
            new coreui.Modal(document.getElementById('BrandDetailModal')).show();
        } catch (e) { console.error(e); }
    }

    async function saveBrand(e) {
        e.preventDefault();
        const form = document.getElementById('brandForm');
        
        if (!form.checkValidity()) {
            e.stopPropagation();
            form.classList.add('was-validated');
            return;
        }

        const id = document.getElementById('editBrandId').value;
        const data = {
            name: document.getElementById('brandName').value,
            description: document.getElementById('brandDescription').value
        };

        try {
            const url = id ? `${API_BASE}/Brands/${id}` : `${API_BASE}/Brands`;
            const method = id ? 'PUT' : 'POST';
            if(id) data.id = parseInt(id);
            
            const response = await fetch(url, {
                method: method,
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            });

            await handleApiError(response);
            coreui.Modal.getInstance(document.getElementById('BrandModal')).hide();
            showAlert(id ? "Cập nhật thành công!" : "Thêm mới thành công!");
            loadBrands();
        } catch (error) { console.error(error); }
    }

    function editBrand(id, name, desc) {
        const form = document.getElementById('brandForm');
        form.classList.remove('was-validated');
        
        document.getElementById('editBrandId').value = id;
        document.getElementById('brandName').value = name;
        document.getElementById('brandDescription').value = desc;
        document.getElementById('BrandModalLabel').innerText = "Cập nhật thương hiệu";
        new coreui.Modal(document.getElementById('BrandModal')).show();
    }

    function deleteBrand(id) {
        showConfirm("Xác nhận xóa", "Bạn có chắc chắn muốn xóa thương hiệu này? Thao tác này không thể hoàn tác.", async () => {
            try {
                const response = await fetch(`${API_BASE}/Brands/${id}`, { method: 'DELETE' });
                await handleApiError(response);
                showAlert("Đã xóa thương hiệu thành công!");
                loadBrands();
            } catch (error) { console.error(error); }
        });
    }

    document.getElementById('BrandModal').addEventListener('hidden.coreui.modal', function () {
        document.getElementById('brandForm').reset();
        document.getElementById('editBrandId').value = '';
        document.getElementById('BrandModalLabel').innerText = "Thêm thương hiệu mới";
    });

    document.getElementById('brandForm').addEventListener('submit', saveBrand);
    document.addEventListener('DOMContentLoaded', loadBrands);
</script>
