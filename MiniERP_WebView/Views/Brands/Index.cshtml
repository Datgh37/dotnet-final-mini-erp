@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2 class="mb-4">Brands</h2>
<div class="card mb-3">
    <div class="card-body">
        <!-- Add Modal -->
        <!-- Trigger -->
        <button type="button" class="btn btn-primary" data-coreui-toggle="modal" data-coreui-target="#AddBrandModal">
            Add New Brand
        </button>
        <div class="modal fade" id="AddBrandModal" tabindex="-1" aria-labelledby="AddBrandModalLabel" aria-hidden="true">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title" id="AddBrandModalLabel">Add New Brand</h5>
                        <button type="button" class="btn-close" data-coreui-dismiss="modal" aria-label="Close"></button>
                    </div>

                    <div class="modal-body">
                        <form id="brandForm">
                            <div class="mb-3">
                                <label for="name" class="form-label">Brand Name</label>
                                <input type="text" class="form-control" id="name" name="name" required>
                            </div>
                            <div class="mb-3">
                                <label for="description" class="form-label">Description</label>
                                <textarea class="form-control" id="description" name="description" rows="3"></textarea>
                            </div>
                        </form>
                    </div>

                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-coreui-dismiss="modal">Close</button>
                        <button type="submit" class="btn btn-primary" form="brandForm">Save</button>
                    </div>
                </div>
            </div>
        </div>
        <!-- Edit Modal -->
        <div class="modal fade" id="EditBrandModal" tabindex="-1" aria-labelledby="EditBrandModalLabel" aria-hidden="true">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title" id="EditBrandModalLabel">Edit Brand</h5>
                        <button type="button" class="btn-close" data-coreui-dismiss="modal" aria-label="Close"></button>
                    </div>

                    <div class="modal-body">
                        <form id="editBrandForm">
                            <div class="mb-3">
                                <label for="name" class="form-label">Brand Name</label>
                                <input type="text" class="form-control" id="editName" name="name" required>
                            </div>
                            <div class="mb-3">
                                <label for="description" class="form-label">Description</label>
                                <textarea class="form-control" id="editDescription" name="description" rows="3"></textarea>
                            </div>
                        </form>
                    </div>

                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-coreui-dismiss="modal">Close</button>
                        <button type="submit" class="btn btn-primary" form="editBrandForm">Save</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<div class="card">
    <div class="card-body">
        <table class="table table-bordered table-hover">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Name</th>
                    <th>Description</th>
                    <th width="150">Actions</th>
                </tr>
            </thead>
            <tbody id="brandTable"></tbody>
        </table>
    </div>
</div>

<script>
    let selectedBrandId = null;

    async function loadBrands() {
        try {
            const response = await fetch('https://localhost:7279/api/Brands');
            const brands = await response.json();
            let html = "";

            brands.forEach(b => {
                html += `
                    <tr>
                        <td>${b.id}</td>
                        <td>${b.name || ''}</td>
                        <td>${b.description || ''}</td>
                        <td>
                            <button
                                type="button"
                                class="btn btn-sm btn-warning btn-edit"
                                data-id="${b.id}"
                                data-name="${b.name || ''}"
                                data-description="${b.description || ''}"
                                data-coreui-toggle="modal"
                                data-coreui-target="#EditBrandModal">
                                Edit
                            </button>
                            <button type="button" class="btn btn-sm btn-danger" onclick="deleteBrand(${b.id})">Delete</button>
                        </td>
                    </tr>
                `;
            });

            document.getElementById("brandTable").innerHTML = html;
        } catch (error) {
            console.log(error);
            alert("Load brands failed");
        }
    }

    document.addEventListener("click", function (e) {
        const editButton = e.target.closest(".btn-edit");
        if (!editButton) return;

        selectedBrandId = editButton.dataset.id;

        document.getElementById("editName").value = editButton.dataset.name || "";
        document.getElementById("editDescription").value = editButton.dataset.description || "";
    });

    document.getElementById("brandForm").addEventListener("submit", async function (e) {
        e.preventDefault();

        const brand = {
            name: document.getElementById("name").value.trim(),
            description: document.getElementById("description").value
        };

        try {
            // Bỏ qua kiểm tra ở client, để cho API xử lý
            const response = await fetch('https://localhost:7279/api/Brands', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify(brand)
            });

            if (response.ok) {
                const modalEl = document.getElementById("AddBrandModal");
                const modal = coreui.Modal.getInstance(modalEl);
                if (modal) {
                    modal.hide();
                }
                document.getElementById("brandForm").reset();
                await loadBrands();
                alert('Brand created successfully!');
            }
            else {
                // *** THAY ĐỔI DUY NHẤT ĐỂ HIỂN THỊ THÔNG BÁO LỖI ***
                // Lấy nội dung lỗi từ API và hiển thị nó
                const errorData = await response.json();
                const errorMessage = errorData.message || 'Failed to create brand';
                alert(errorMessage);
            }

        } catch (error) {
            console.log(error);
            alert('Error: ' + error.message);
        }
    });

    document.getElementById("editBrandForm").addEventListener("submit", async function (e) {
        e.preventDefault();

        if (!selectedBrandId) {
            alert("No brand selected");
            return;
        }

        const brand = {
            id: parseInt(selectedBrandId),
            name: document.getElementById("editName").value,
            description: document.getElementById("editDescription").value
        };

        try {
            const response = await fetch(`https://localhost:7279/api/Brands/${selectedBrandId}`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(brand)
            });

            if (response.ok) {
                const modalEl = document.getElementById("EditBrandModal");
                const modal = coreui.Modal.getInstance(modalEl);
                if (modal) {
                    modal.hide();
                }

                selectedBrandId = null;
                await loadBrands();
                alert('Brand updated successfully!');
            } else {
                // Thêm xử lý lỗi tương tự cho form Edit
                const errorData = await response.json();
                const errorMessage = errorData.message || 'Failed to update brand';
                alert(errorMessage);
            }
        } catch (error) {
            console.log(error);
            alert('Error: ' + error.message);
        }
    });

    async function deleteBrand(id) {
        if (confirm('Are you sure?')) {
            try {
                const response = await fetch(`https://localhost:7279/api/Brands/${id}`, {
                    method: 'DELETE'
                });

                if (response.ok) {
                    alert('Brand deleted successfully!');
                    loadBrands();
                } else {
                    alert('Failed to delete brand');
                }
            } catch (error) {
                console.log(error);
                alert('Error: ' + error.message);
            }
        }
    }

    loadBrands();
</script>