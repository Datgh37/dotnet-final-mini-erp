@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Quản lý Danh mục</h2>
    <button class="btn btn-primary" data-coreui-toggle="modal" data-coreui-target="#AddCateModal">
        <i class="cil-plus"></i> Thêm mới
    </button>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-body-tertiary">
                    <tr>
                        <th class="ps-4">ID</th>
                        <th>Tên danh mục</th>
                        <th>Mô tả</th>
                        <th class="text-end pe-4">Thao tác</th>
                    </tr>
                </thead>
                <tbody id="categoryTable">
                    <!-- Data will be loaded here -->
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Category Detail Modal -->
<div class="modal fade" id="CategoryDetailModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-body-tertiary">
                <h5 class="modal-title">Chi tiết danh mục</h5>
                <button type="button" class="btn-close" data-coreui-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-4">
                    <label class="text-body-secondary small d-block text-uppercase mb-1">Tên danh mục</label>
                    <h3 id="detailCatName" class="text-primary fw-bold"></h3>
                </div>
                <div class="mb-3">
                    <label class="text-body-secondary small d-block text-uppercase mb-1">Mô tả</label>
                    <p id="detailCatDescription" class="bg-body-tertiary p-3 rounded border text-body"></p>
                </div>
                <div class="text-body-secondary small">ID hệ thống: <span id="detailCatId"></span></div>
            </div>
            <div class="modal-footer bg-body-tertiary">
                <button type="button" class="btn btn-secondary" data-coreui-dismiss="modal">Đóng</button>
                <button type="button" class="btn btn-info text-white" id="btnEditCatFromDetail">Sửa</button>
            </div>
        </div>
    </div>
</div>

<!-- Category Modal -->
<div class="modal fade" id="AddCateModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <form id="categoryForm" class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="AddCateModalLabel">Thêm danh mục mới</h5>
                <button type="button" class="btn-close" data-coreui-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="editId">
                <div class="mb-3">
                    <label class="form-label">Tên danh mục <span class="text-danger">*</span></label>
                    <input type="text" class="form-control" id="name" required>
                </div>
                <div class="mb-3">
                    <label class="form-label">Mô tả</label>
                    <textarea class="form-control" id="description" rows="3"></textarea>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-coreui-dismiss="modal">Hủy</button>
                <button type="submit" class="btn btn-primary">Lưu thay đổi</button>
            </div>
        </form>
    </div>
</div>

<script>
    async function loadCategories() {
        try {
            const response = await fetch(`${API_BASE}/Categories`);
            if (!response.ok) return;
            const categories = await response.json();

            window.renderTable('categoryTable', categories, cat => `
                <tr>
                    <td class="ps-4 text-body-secondary">${cat.id}</td>
                    <td><span class="fw-semibold">${cat.name}</span></td>
                    <td class="text-body-secondary">${cat.description || '-'}</td>
                    <td class="text-end pe-4">
                        <div class="btn-group">
                            <button class="btn btn-sm btn-primary" onclick="viewCategoryDetail(${cat.id})" title="Xem chi tiết">
                                <i class="cil-eye"></i> <span class="d-none d-lg-inline">Xem</span>
                            </button>
                            <button class="btn btn-sm btn-info text-white" onclick="editCategory(${cat.id}, '${cat.name}', '${cat.description || ''}')" title="Sửa">
                                <i class="cil-pencil"></i> <span class="d-none d-lg-inline">Sửa</span>
                            </button>
                            <button class="btn btn-sm btn-danger text-white" onclick="deleteCategory(${cat.id})" title="Xóa">
                                <i class="cil-trash"></i>
                            </button>
                        </div>
                    </td>
                </tr>
            `);
        } catch (e) { console.error(e); }
    }

    async function viewCategoryDetail(id) {
        try {
            const response = await fetch(`${API_BASE}/Categories/${id}`);
            const cat = await response.json();
            
            document.getElementById('detailCatName').innerText = cat.name;
            document.getElementById('detailCatDescription').innerText = cat.description || 'Không có mô tả.';
            document.getElementById('detailCatId').innerText = cat.id;
            
            document.getElementById('btnEditCatFromDetail').onclick = () => {
                coreui.Modal.getInstance(document.getElementById('CategoryDetailModal')).hide();
                editCategory(cat.id, cat.name, cat.description || '');
            };
            
            new coreui.Modal(document.getElementById('CategoryDetailModal')).show();
        } catch (e) { console.error(e); }
    }

    async function saveCategory(e) {
        e.preventDefault();
        const form = document.getElementById('categoryForm');
        
        if (!form.checkValidity()) {
            e.stopPropagation();
            form.classList.add('was-validated');
            return;
        }

        const id = document.getElementById('editId').value;
        const data = {
            name: document.getElementById('name').value,
            description: document.getElementById('description').value
        };

        try {
            const url = id ? `${API_BASE}/Categories/${id}` : `${API_BASE}/Categories`;
            const method = id ? 'PUT' : 'POST';
            if(id) data.id = parseInt(id); 
            
            const response = await fetch(url, {
                method: method,
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            });

            await handleApiError(response);
            coreui.Modal.getInstance(document.getElementById('AddCateModal')).hide();
            showAlert(id ? "Cập nhật thành công!" : "Thêm mới thành công!");
            loadCategories();
        } catch (error) { console.error(error); }
    }

    function editCategory(id, name, desc) {
        const form = document.getElementById('categoryForm');
        form.classList.remove('was-validated');
        
        document.getElementById('editId').value = id;
        document.getElementById('name').value = name;
        document.getElementById('description').value = desc;
        document.getElementById('AddCateModalLabel').innerText = "Cập nhật danh mục";
        new coreui.Modal(document.getElementById('AddCateModal')).show();
    }

    async function deleteCategory(id) {
        if (!confirm('Xác nhận xóa danh mục này?')) return;
        try {
            const response = await fetch(`${API_BASE}/Categories/${id}`, { method: 'DELETE' });
            await handleApiError(response);
            showAlert("Đã xóa thành công!");
            loadCategories();
        } catch (error) { console.error(error); }
    }

    document.getElementById('AddCateModal').addEventListener('hidden.coreui.modal', function () {
        document.getElementById('categoryForm').reset();
        document.getElementById('editId').value = '';
        document.getElementById('AddCateModalLabel').innerText = "Thêm danh mục mới";
    });

    document.getElementById('categoryForm').addEventListener('submit', saveCategory);
    document.addEventListener('DOMContentLoaded', loadCategories);
</script>
