@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="mb-4 d-flex justify-content-between align-items-center">
    <h2 class="mb-0">Hệ thống Quản trị MiniERP</h2>
    <div id="dashboard-timer" class="text-body-secondary small"></div>
</div>

<!-- Summary Cards -->
<div class="row g-4 mb-4">
    <!-- Revenue -->
    <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm bg-primary text-white h-100">
            <div class="card-body">
                <div class="text-white text-opacity-75 small fw-bold">Doanh thu (30 ngày)</div>
                <div class="d-flex align-items-center justify-content-between mt-2">
                    <h3 class="mb-0 fw-bold" id="stat-revenue">0 đ</h3>
                    <div class="bg-white bg-opacity-25 rounded p-2">
                        <i class="cil-money icon icon-lg"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!-- Low Stock -->
    <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm bg-warning text-white h-100">
            <div class="card-body">
                <div class="text-white text-opacity-75 small fw-bold">Cảnh báo tồn kho</div>
                <div class="d-flex align-items-center justify-content-between mt-2">
                    <h3 class="mb-0 fw-bold" id="stat-lowstock">0</h3>
                    <div class="bg-white bg-opacity-25 rounded p-2">
                        <i class="cil-warning icon icon-lg"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!-- Top Selling -->
    <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm bg-success text-white h-100">
            <div class="card-body">
                <div class="text-white text-opacity-75 small fw-bold">Sản phẩm bán chạy</div>
                <div class="d-flex align-items-center justify-content-between mt-2">
                    <h3 class="mb-0 fw-bold" id="stat-topselling">0</h3>
                    <div class="bg-white bg-opacity-25 rounded p-2">
                        <i class="cil-star icon icon-lg"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!-- Total Products -->
    <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm bg-info text-white h-100">
            <div class="card-body">
                <div class="text-white text-opacity-75 small fw-bold">Tổng sản phẩm</div>
                <div class="d-flex align-items-center justify-content-between mt-2">
                    <h3 class="mb-0 fw-bold" id="stat-totalproducts">0</h3>
                    <div class="bg-white bg-opacity-25 rounded p-2">
                        <i class="cil-tags icon icon-lg"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Chart Row -->
<div class="row mb-4">
    <div class="col-12">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center border-bottom">
                <span class="fw-bold"><i class="cil-chart me-2"></i>Biểu đồ Doanh thu</span>
                <div class="d-flex gap-2 align-items-center">
                    <input type="date" id="chartFrom" class="form-control form-control-sm" style="width: 140px;">
                    <span>-</span>
                    <input type="date" id="chartTo" class="form-control form-control-sm" style="width: 140px;">
                    <button class="btn btn-sm btn-primary" onclick="loadRevenueChart()">Lọc</button>
                </div>
            </div>
            <div class="card-body">
                <div style="height: 350px;">
                    <canvas id="revenueChart"></canvas>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Bottom Tables Row -->
<div class="row g-4">
    <!-- Top Selling Table -->
    <div class="col-md-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white py-3 fw-bold border-bottom">Top 5 Sản phẩm bán chạy</div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="bg-body-tertiary">
                            <tr>
                                <th class="ps-3">Sản phẩm</th>
                                <th class="text-center">Số lượng</th>
                                <th class="text-end pe-3">Doanh thu</th>
                            </tr>
                        </thead>
                        <tbody id="topSellingTable"></tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- Low Stock Table -->
    <div class="col-md-6">
        <div class="card border-0 shadow-sm h-100 border-top border-4 border-danger">
            <div class="card-header bg-white py-3 fw-bold border-bottom d-flex justify-content-between">
                Cảnh báo hết hàng
                <span class="badge bg-danger rounded-pill" id="lowStockCount">0</span>
            </div>
            <div class="card-body p-0">
                <ul class="list-group list-group-flush" id="lowStockList"></ul>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    let myChart = null;

    async function loadDashboardData() {
        try {
            document.getElementById('dashboard-timer').innerText = 'Cập nhật lần cuối: ' + new Date().toLocaleTimeString();

            // 1. Revenue & Chart
            await loadRevenueChart();

            // 2. Top Selling
            const topRes = await fetch(`${API_BASE}/Reports/top-selling?top=5`);
            if (topRes.ok) {
                const topData = await topRes.json();
                document.getElementById('stat-topselling').innerText = topData.length;
                window.renderTable('topSellingTable', topData, t => `
                    <tr>
                        <td class="ps-3">
                            <div class="fw-semibold text-primary small">${t.name}</div>
                            <div class="text-body-secondary" style="font-size: 0.7rem;">SKU: ${t.sku}</div>
                        </td>
                        <td class="text-center fw-bold">${t.totalSold}</td>
                        <td class="text-end pe-3 text-success fw-bold">${t.totalRevenue.toLocaleString()} đ</td>
                    </tr>
                `);
            }

            // 3. Low Stock
            const lowRes = await fetch(`${API_BASE}/Reports/low-stock?threshold=10`);
            if (lowRes.ok) {
                const lowData = await lowRes.json();
                document.getElementById('stat-lowstock').innerText = lowData.length;
                document.getElementById('lowStockCount').innerText = lowData.length;
                
                let listHtml = '';
                lowData.forEach(p => {
                    listHtml += `
                        <li class="list-group-item d-flex justify-content-between align-items-center py-2">
                            <div>
                                <div class="fw-bold small">${p.name}</div>
                                <div class="text-body-secondary" style="font-size: 0.7rem;">SKU: ${p.sku}</div>
                            </div>
                            <span class="badge bg-danger rounded-pill">${p.stockQuantity}</span>
                        </li>
                    `;
                });
                document.getElementById('lowStockList').innerHTML = listHtml || '<li class="list-group-item text-center text-body-secondary py-4">Tất cả sản phẩm đủ tồn kho</li>';
            }

            // 4. Total Products
            const prodRes = await fetch(`${API_BASE}/Products`);
            if (prodRes.ok) {
                const prodData = await prodRes.json();
                document.getElementById('stat-totalproducts').innerText = prodData.length;
            }

        } catch (e) {
            console.error("Dashboard error:", e);
        }
    }

    async function loadRevenueChart() {
        const from = document.getElementById('chartFrom').value;
        const to = document.getElementById('chartTo').value;
        
        let url = `${API_BASE}/Reports/revenue?days=30`;
        if (from && to) url = `${API_BASE}/Reports/revenue?from=${from}&to=${to}`;

        try {
            const res = await fetch(url);
            if (!res.ok) return;
            const data = await res.json();

            // Total revenue for stat
            const total = data.reduce((sum, item) => sum + (item.dailyRevenue || 0), 0);
            document.getElementById('stat-revenue').innerText = total.toLocaleString('vi-VN') + ' đ';

            const ctx = document.getElementById('revenueChart').getContext('2d');
            const labels = data.map(d => new Date(d.orderDate).toLocaleDateString('vi-VN'));
            const values = data.map(d => d.dailyRevenue);

            if (myChart) myChart.destroy();

            myChart = new Chart(ctx, {
                type: 'line',
                data: {
                    labels: labels,
                    datasets: [{
                        label: 'Doanh thu (đ)',
                        data: values,
                        borderColor: '#321fdb',
                        backgroundColor: 'rgba(50, 31, 219, 0.1)',
                        fill: true,
                        tension: 0.4
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: {
                        y: { 
                            beginAtZero: true,
                            ticks: { callback: value => value.toLocaleString() + ' đ' }
                        }
                    }
                }
            });
        } catch (e) { console.error("Chart error:", e); }
    }

    document.addEventListener('DOMContentLoaded', loadDashboardData);
</script>