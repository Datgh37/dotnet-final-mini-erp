@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2 class="mb-4">Lịch sử biến động Kho</h2>

<div class="row mb-4 g-4">
    <!-- Filter Card -->
    <div class="col-md-7">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white py-3 fw-bold">Tra cứu lịch sử</div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label small">Sản phẩm</label>
                        <select class="form-select" id="filterProduct"></select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label small">Loại biến động</label>
                        <select class="form-select" id="filterType">
                            <option value="">-- Tất cả --</option>
                            <option value="IN">Nhập kho (IN)</option>
                            <option value="OUT">Xuất kho (OUT)</option>
                            <option value="ADJUSTMENT">Điều chỉnh (ADJUSTMENT)</option>
                        </select>
                    </div>
                    <div class="col-md-2 d-flex align-items-end">
                        <button class="btn btn-primary w-100" onclick="loadMovements()">Lọc</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Quick Adjust Card -->
    <div class="col-md-5">
        <div class="card border-0 shadow-sm h-100 border-start border-4 border-warning">
            <div class="card-header bg-white py-3 fw-bold">Điều chỉnh nhanh</div>
            <form id="adjustForm" class="card-body">
                <div class="row g-3">
                    <div class="col-12">
                        <select class="form-select" id="adjustProduct" required></select>
                    </div>
                    <div class="col-md-4">
                        <input type="number" class="form-control" id="adjustQty" placeholder="SL (+/-)" required>
                    </div>
                    <div class="col-md-8">
                        <input type="text" class="form-control" id="adjustReason" placeholder="Lý do điều chỉnh..." required>
                    </div>
                    <div class="col-12">
                        <button type="submit" class="btn btn-warning w-100 fw-bold">Cập nhật kho</button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Movements Table -->
<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-body-tertiary">
                    <tr>
                        <th class="ps-4">Sản phẩm</th>
                        <th>Loại</th>
                        <th class="text-center">Số lượng</th>
                        <th>Thời gian</th>
                        <th class="pe-4">Tham chiếu / Lý do</th>
                    </tr>
                </thead>
                <tbody id="movementTable"></tbody>
            </table>
        </div>
    </div>
</div>

<script>
    async function init() {
        await populateSelect('filterProduct', 'Products', '-- Tất cả sản phẩm --');
        await populateSelect('adjustProduct', 'Products', '-- Chọn sản phẩm --');
        loadMovements();
    }

    async function loadMovements() {
        const productId = document.getElementById('filterProduct').value;
        const type = document.getElementById('filterType').value;
        
        const params = new URLSearchParams();
        if (productId) params.append('productId', productId);
        if (type) params.append('movementType', type);

        try {
            let url = `${API_BASE}/Inventory/movements`;
            if (params.toString()) url += `?${params.toString()}`;
            const response = await fetch(url);
            if (!response.ok) return;
            const data = await response.json();

            window.renderTable('movementTable', data, m => {
                let badgeClass = 'bg-secondary';
                if(m.movementType === 'In') badgeClass = 'bg-success';
                else if(m.movementType === 'Out') badgeClass = 'bg-danger';
                else if(m.movementType === 'Adjustment') badgeClass = 'bg-warning text-dark';

                return `
                    <tr>
                        <td class="ps-4">
                            <span class="fw-semibold text-primary">SP-${m.productId}</span>
                        </td>
                        <td><span class="badge ${badgeClass}">${m.movementType}</span></td>
                        <td class="text-center fw-bold ${m.quantity > 0 ? 'text-success' : 'text-danger'}">
                            ${m.quantity > 0 ? '+' + m.quantity : m.quantity}
                        </td>
                        <td class="text-body-secondary small">${new Date(m.createdAt).toLocaleString('vi-VN')}</td>
                        <td class="pe-4 small">${m.reference || m.reason || '-'}</td>
                    </tr>
                `;
            });
        } catch (e) { console.error(e); }
    }

    async function handleAdjust(e) {
        e.preventDefault();
        const user = JSON.parse(localStorage.getItem('user') || '{}');
        const userId = user.id || 1;

        const data = {
            productId: parseInt(document.getElementById('adjustProduct').value),
            quantity: parseInt(document.getElementById('adjustQty').value),
            reason: document.getElementById('adjustReason').value
        };

        try {
            const response = await fetch(`${API_BASE}/Inventory/adjust?userId=${userId}`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            });

            await handleApiError(response);
            document.getElementById('adjustForm').reset();
            loadMovements();
            alert("Điều chỉnh kho thành công!");
        } catch (e) { alert(e.message); }
    }

    document.getElementById('adjustForm').addEventListener('submit', handleAdjust);
    document.addEventListener('DOMContentLoaded', init);
</script>
