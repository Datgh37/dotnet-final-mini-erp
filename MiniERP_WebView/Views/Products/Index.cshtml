@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2 class="mb-4">Products</h2>

<div class="card mb-3">
    <div class="card-body">
        <button type="button" class="btn btn-primary" data-coreui-toggle="modal" data-coreui-target="#AddProductModal">
            Add New Product
        </button>

        <!-- Add Modal -->
        <div class="modal fade" id="AddProductModal" tabindex="-1" aria-labelledby="AddProductModalLabel" aria-hidden="true">
            <div class="modal-dialog modal-lg">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title" id="AddProductModalLabel">Add New Product</h5>
                        <button type="button" class="btn-close" data-coreui-dismiss="modal" aria-label="Close"></button>
                    </div>

                    <div class="modal-body">
                        <form id="addProductForm">
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label for="addCategoryId" class="form-label">Category ID</label>
                                    <input type="number" class="form-control" id="addCategoryId" required>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label for="addBrandId" class="form-label">Brand ID</label>
                                    <input type="number" class="form-control" id="addBrandId" required>
                                </div>
                            </div>

                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label for="addSku" class="form-label">SKU</label>
                                    <input type="text" class="form-control" id="addSku" required>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label for="addName" class="form-label">Product Name</label>
                                    <input type="text" class="form-control" id="addName" required>
                                </div>
                            </div>

                            <div class="mb-3">
                                <label for="addDescription" class="form-label">Description</label>
                                <textarea class="form-control" id="addDescription" rows="3" required></textarea>
                            </div>

                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label for="addUnit" class="form-label">Unit</label>
                                    <input type="text" class="form-control" id="addUnit" required>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label for="addCostPrice" class="form-label">Cost Price</label>
                                    <input type="number" step="0.01" class="form-control" id="addCostPrice" required>
                                </div>
                            </div>

                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label for="addRetailPrice" class="form-label">Retail Price</label>
                                    <input type="number" step="0.01" class="form-control" id="addRetailPrice" required>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label for="addStockQuantity" class="form-label">Stock Quantity</label>
                                    <input type="number" class="form-control" id="addStockQuantity" required>
                                </div>
                            </div>

                            <div class="mb-3">
                                <label for="addImageUrl" class="form-label">Image URL</label>
                                <input type="text" class="form-control" id="addImageUrl">
                            </div>
                        </form>
                    </div>

                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-coreui-dismiss="modal">Close</button>
                        <button type="submit" class="btn btn-primary" form="addProductForm">Save</button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Edit Modal -->
        <div class="modal fade" id="EditProductModal" tabindex="-1" aria-labelledby="EditProductModalLabel" aria-hidden="true">
            <div class="modal-dialog modal-lg">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title" id="EditProductModalLabel">Edit Product</h5>
                        <button type="button" class="btn-close" data-coreui-dismiss="modal" aria-label="Close"></button>
                    </div>

                    <div class="modal-body">
                        <form id="editProductForm">
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label for="editId" class="form-label">Product ID</label>
                                    <input type="number" class="form-control" id="editId" readonly>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label for="editCategoryId" class="form-label">Category ID</label>
                                    <input type="number" class="form-control" id="editCategoryId" required>
                                </div>
                            </div>

                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label for="editBrandId" class="form-label">Brand ID</label>
                                    <input type="number" class="form-control" id="editBrandId" required>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label for="editSku" class="form-label">SKU</label>
                                    <input type="text" class="form-control" id="editSku" required>
                                </div>
                            </div>

                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label for="editName" class="form-label">Product Name</label>
                                    <input type="text" class="form-control" id="editName" required>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label for="editUnit" class="form-label">Unit</label>
                                    <input type="text" class="form-control" id="editUnit" required>
                                </div>
                            </div>

                            <div class="mb-3">
                                <label for="editDescription" class="form-label">Description</label>
                                <textarea class="form-control" id="editDescription" rows="3" required></textarea>
                            </div>

                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label for="editCostPrice" class="form-label">Cost Price</label>
                                    <input type="number" step="0.01" class="form-control" id="editCostPrice" required>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label for="editRetailPrice" class="form-label">Retail Price</label>
                                    <input type="number" step="0.01" class="form-control" id="editRetailPrice" required>
                                </div>
                            </div>

                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label for="editStockQuantity" class="form-label">Stock Quantity</label>
                                    <input type="number" class="form-control" id="editStockQuantity" required>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label for="editImageUrl" class="form-label">Image URL</label>
                                    <input type="text" class="form-control" id="editImageUrl">
                                </div>
                            </div>
                        </form>
                    </div>

                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-coreui-dismiss="modal">Close</button>
                        <button type="submit" class="btn btn-primary" form="editProductForm">Save</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <table class="table table-bordered table-hover">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Category ID</th>
                    <th>Brand ID</th>
                    <th>SKU</th>
                    <th>Name</th>
                    <th>Unit</th>
                    <th>Description</th>
                    <th>Cost Price</th>
                    <th>Retail Price</th>
                    <th>Stock</th>
                    <th width="200">Image</th>
                    <th width="150">Actions</th>
                </tr>
            </thead>
            <tbody id="productTable"></tbody>
        </table>
    </div>
</div>

<script>
    let selectedProductId = null;

    async function loadProducts() {
        try {
            const response = await fetch('https://localhost:7279/api/Products');
            const products = await response.json();

            let html = "";
            products.forEach(p => {
                html += `
                    <tr>
                        <td>${p.id}</td>
                        <td>${p.categoryId ?? ''}</td>
                        <td>${p.brandId ?? ''}</td>
                        <td>${p.sku || ''}</td>
                        <td>${p.name || ''}</td>
                        <td>${p.unit || ''}</td>
                        <td>${p.description || ''}</td>
                        <td>${p.costPrice ?? ''}</td>
                        <td>${p.retailPrice ?? ''}</td>
                        <td>${p.stockQuantity ?? ''}</td>
                        <td>
                            <img src="${p.imageUrl || ''}"
                                 width="60"
                                 height="60"
                                 style="object-fit:cover;border-radius:8px;"
                                 onerror="this.src='https://via.placeholder.com/60?text=No+Image'"/>
                        </td>
                        <td>
                            <button
                                type="button"
                                class="btn btn-sm btn-warning btn-edit"
                                data-id="${p.id}"
                                data-categoryid="${p.categoryId ?? ''}"
                                data-brandid="${p.brandId ?? ''}"
                                data-sku="${p.sku || ''}"
                                data-name="${p.name || ''}"
                                data-description="${p.description || ''}"
                                data-unit="${p.unit || ''}"
                                data-costprice="${p.costPrice ?? ''}"
                                data-retailprice="${p.retailPrice ?? ''}"
                                data-stockquantity="${p.stockQuantity ?? ''}"
                                data-imageurl="${p.imageUrl || ''}"
                                data-coreui-toggle="modal"
                                data-coreui-target="#EditProductModal">
                                Edit
                            </button>
                            <button type="button" class="btn btn-sm btn-danger" onclick="deleteProduct(${p.id})">Delete</button>
                        </td>
                    </tr>
                `;
            });

            document.getElementById("productTable").innerHTML = html;
        }
        catch (error) {
            console.log(error);
            alert("Load products failed");
        }
    }

    document.addEventListener("click", function (e) {
        const editButton = e.target.closest(".btn-edit");
        if (!editButton) return;

        selectedProductId = editButton.dataset.id;

        document.getElementById("editId").value = editButton.dataset.id || "";
        document.getElementById("editCategoryId").value = editButton.dataset.categoryid || "";
        document.getElementById("editBrandId").value = editButton.dataset.brandid || "";
        document.getElementById("editSku").value = editButton.dataset.sku || "";
        document.getElementById("editName").value = editButton.dataset.name || "";
        document.getElementById("editDescription").value = editButton.dataset.description || "";
        document.getElementById("editUnit").value = editButton.dataset.unit || "";
        document.getElementById("editCostPrice").value = editButton.dataset.costprice || "";
        document.getElementById("editRetailPrice").value = editButton.dataset.retailprice || "";
        document.getElementById("editStockQuantity").value = editButton.dataset.stockquantity || "";
        document.getElementById("editImageUrl").value = editButton.dataset.imageurl || "";
    });

    document.getElementById("addProductForm").addEventListener("submit", async function (e) {
        e.preventDefault();

        const product = {
            categoryId: parseInt(document.getElementById("addCategoryId").value),
            brandId: parseInt(document.getElementById("addBrandId").value),
            sku: document.getElementById("addSku").value,
            name: document.getElementById("addName").value,
            description: document.getElementById("addDescription").value,
            unit: document.getElementById("addUnit").value,
            costPrice: parseFloat(document.getElementById("addCostPrice").value),
            retailPrice: parseFloat(document.getElementById("addRetailPrice").value),
            stockQuantity: parseInt(document.getElementById("addStockQuantity").value),
            imageUrl: document.getElementById("addImageUrl").value
        };

        try {
            const response = await fetch('https://localhost:7279/api/Products', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(product)
            });

            if (response.ok) {
                const modalEl = document.getElementById("AddProductModal");
                const modal = coreui.Modal.getOrCreateInstance(modalEl);
                modal.hide();

                document.getElementById("addProductForm").reset();
                await loadProducts();
                alert('Product created successfully!');
            } else {
                const error = await response.text();
                alert('Failed to create product: ' + error);
            }
        } catch (error) {
            console.log(error);
            alert('Error: ' + error.message);
        }
    });

    document.getElementById("editProductForm").addEventListener("submit", async function (e) {
        e.preventDefault();

        if (!selectedProductId) {
            alert("No product selected");
            return;
        }

        const product = {
            id: parseInt(selectedProductId),
            categoryId: parseInt(document.getElementById("editCategoryId").value),
            brandId: parseInt(document.getElementById("editBrandId").value),
            sku: document.getElementById("editSku").value,
            name: document.getElementById("editName").value,
            description: document.getElementById("editDescription").value,
            unit: document.getElementById("editUnit").value,
            costPrice: parseFloat(document.getElementById("editCostPrice").value),
            retailPrice: parseFloat(document.getElementById("editRetailPrice").value),
            stockQuantity: parseInt(document.getElementById("editStockQuantity").value),
            imageUrl: document.getElementById("editImageUrl").value
        };

        try {
            const response = await fetch(`https://localhost:7279/api/Products/${selectedProductId}`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(product)
            });

            if (response.ok) {
                const modalEl = document.getElementById("EditProductModal");
                const modal = coreui.Modal.getOrCreateInstance(modalEl);
                modal.hide();

                selectedProductId = null;
                await loadProducts();
                alert('Product updated successfully!');
            } else {
                const error = await response.text();
                alert('Failed to update product: ' + error);
            }
        } catch (error) {
            console.log(error);
            alert('Error: ' + error.message);
        }
    });

    async function deleteProduct(id) {
        if (confirm('Are you sure you want to delete this product?')) {
            try {
                const response = await fetch(`https://localhost:7279/api/Products/${id}`, {
                    method: 'DELETE'
                });

                if (response.ok) {
                    alert('Product deleted successfully!');
                    loadProducts();
                } else {
                    alert('Failed to delete product');
                }
            } catch (error) {
                console.log(error);
                alert('Error: ' + error.message);
            }
        }
    }

    loadProducts();
</script>