@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Danh sách Sản phẩm</h2>
    <button class="btn btn-primary" onclick="openCreateModal()">Thêm sản phẩm</button>
</div>

<!-- Search & Filter Bar -->
<div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-4">
                <input type="text" class="form-control" id="filterSearch" placeholder="Tìm tên hoặc SKU...">
            </div>
            <div class="col-md-3">
                <select class="form-select" id="filterCategory"></select>
            </div>
            <div class="col-md-3">
                <select class="form-select" id="filterBrand"></select>
            </div>
            <div class="col-md-2">
                <button class="btn btn-info w-100" onclick="loadProducts()">Lọc</button>
            </div>
        </div>
    </div>
</div>

<!-- Products Table -->
<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light text-nowrap">
                    <tr>
                        <th class="ps-4">SKU</th>
                        <th>Tên sản phẩm</th>
                        <th>Danh mục</th>
                        <th>Thương hiệu</th>
                        <th class="text-end">Giá bán</th>
                        <th class="text-center">Tồn kho</th>
                        <th class="text-end pe-4">Thao tác</th>
                    </tr>
                </thead>
                <tbody id="productTable"></tbody>
            </table>
        </div>
    </div>
</div>

<!-- Product Modal -->
<div class="modal fade" id="ProductModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <form id="productForm" class="modal-content needs-validation" novalidate>
            <div class="modal-header">
                <h5 class="modal-title" id="ProductModalLabel">Sản phẩm</h5>
                <button type="button" class="btn-close" data-coreui-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="editId">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">Tên sản phẩm <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="name" required>
                        <div class="invalid-feedback">Tên SP là bắt buộc.</div>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Mã SKU <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="sku" required>
                        <div class="invalid-feedback">SKU là bắt buộc.</div>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Danh mục</label>
                        <select class="form-select" id="categoryId"></select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Thương hiệu</label>
                        <select class="form-select" id="brandId"></select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Đơn vị</label>
                        <input type="text" class="form-control" id="unit" placeholder="Cái, Bộ...">
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Giá vốn</label>
                        <input type="number" class="form-control" id="costPrice" value="0" min="0" step="0.01">
                        <div class="invalid-feedback">Giá vốn >= 0.</div>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Giá bán</label>
                        <input type="number" class="form-control" id="retailPrice" value="0" min="0" step="0.01">
                        <div class="invalid-feedback">Giá bán >= 0.</div>
                    </div>
                    <div class="col-12">
                        <label class="form-label">Mô tả</label>
                        <textarea class="form-control" id="description" rows="3"></textarea>
                    </div>
                    <div class="col-12">
                        <label class="form-label">Link ảnh (URL)</label>
                        <input type="text" class="form-control" id="imageUrl">
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-coreui-dismiss="modal">Hủy</button>
                <button type="submit" class="btn btn-primary">Lưu sản phẩm</button>
            </div>
        </form>
    </div>
</div>

<!-- Product Detail Modal -->
<div class="modal fade" id="ProductDetailModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header border-bottom">
                <h5 class="modal-title">Chi tiết sản phẩm</h5>
                <button type="button" class="btn-close" data-coreui-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="row">
                    <div class="col-md-5 text-center mb-3">
                        <img id="detailImage" src="" class="img-fluid rounded shadow-sm border w-100" style="max-height: 300px; object-fit: contain; display: none;">
                        <div id="detailNoImage" class="bg-body-tertiary d-flex align-items-center justify-content-center rounded border w-100" style="height: 250px;">
                            <div class="text-center">
                                <i class="cil-image text-body-secondary fs-1 d-block mb-2"></i>
                                <span class="text-body-secondary small">Không có hình ảnh</span>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-7">
                        <h3 id="detailName" class="text-primary mb-1"></h3>
                        <div id="detailSKU" class="text-body-secondary fw-bold mb-3"></div>
                        <div class="row g-4">
                            <div class="col-6">
                                <label class="text-body-secondary small d-block text-uppercase">Danh mục</label>
                                <div id="detailCategory" class="fw-bold text-body"></div>
                            </div>
                            <div class="col-6">
                                <label class="text-body-secondary small d-block text-uppercase">Thương hiệu</label>
                                <div id="detailBrand" class="fw-bold text-body"></div>
                            </div>
                            <div class="col-6">
                                <label class="text-body-secondary small d-block text-uppercase">Giá vốn</label>
                                <div id="detailCost" class="fw-bold text-danger fs-5"></div>
                            </div>
                            <div class="col-6">
                                <label class="text-body-secondary small d-block text-uppercase">Giá bán lẻ</label>
                                <div id="detailRetail" class="fw-bold text-success fs-5"></div>
                            </div>
                            <div class="col-6">
                                <label class="text-body-secondary small d-block text-uppercase">Đơn vị</label>
                                <div id="detailUnit" class="fw-bold text-body"></div>
                            </div>
                            <div class="col-6">
                                <label class="text-body-secondary small d-block text-uppercase">Tồn kho hiện tại</label>
                                <div id="detailStock"></div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="mt-3">
                    <label class="text-body-secondary small d-block text-uppercase mb-1">Mô tả sản phẩm</label>
                    <div id="detailDescription" class="p-3 bg-body-tertiary rounded border small text-body" style="min-height: 80px;"></div>
                </div>

                <div class="mt-4 pt-3 border-top d-flex justify-content-between text-body-secondary small">
                    <div>Ngày tạo: <span id="detailCreatedAt" class="fw-semibold"></span></div>
                    <div>Cập nhật: <span id="detailUpdatedAt" class="fw-semibold"></span></div>
                </div>
            </div>
            <div class="modal-footer bg-body-tertiary">
                <button type="button" class="btn btn-secondary" data-coreui-dismiss="modal">Đóng</button>
                <button type="button" class="btn btn-info" id="btnEditFromDetail">Sửa sản phẩm</button>
            </div>
        </div>
    </div>
</div>

<script>
    let categories = [];
    let brands = [];

    async function init() {
        categories = await populateSelect('filterCategory', 'Categories', '-- Tất cả danh mục --');
        brands = await populateSelect('filterBrand', 'Brands', '-- Tất cả thương hiệu --');
        
        await populateSelect('categoryId', 'Categories');
        await populateSelect('brandId', 'Brands');
        
        loadProducts();
    }

    async function loadProducts() {
        const term = document.getElementById('filterSearch').value;
        const catId = document.getElementById('filterCategory').value;
        const bId = document.getElementById('filterBrand').value;

        const params = new URLSearchParams();
        if (term && term.trim()) params.append('searchTerm', term.trim());
        if (catId && catId !== "") params.append('categoryId', catId);
        if (bId && bId !== "") params.append('brandId', bId);

        try {
            let url = `${API_BASE}/Products`;
            const qs = params.toString();
            if (qs) url += `?${qs}`;
            const response = await fetch(url);
            if (!response.ok) return;
            const data = await response.json();

            window.renderTable('productTable', data, p => {
                const cat = categories.find(c => c.id === p.categoryId)?.name || '-';
                const brand = brands.find(b => b.id === p.brandId)?.name || '-';
                
                return `
                    <tr>
                        <td class="ps-4 fw-bold text-primary">${p.sku}</td>
                        <td>
                            <div class="d-flex align-items-center">
                                ${p.imageUrl ? `<img src="${p.imageUrl}" class="rounded me-2" width="32" height="32" style="object-fit: cover;">` : ''}
                                <span class="fw-semibold">${p.name}</span>
                            </div>
                        </td>
                        <td><span class="badge bg-light text-dark">${cat}</span></td>
                        <td>${brand}</td>
                        <td class="text-end money-text fw-semibold">${p.retailPrice.toLocaleString()} đ</td>
                        <td class="text-center">
                            <span class="badge ${p.stockQuantity <= 5 ? 'bg-danger' : 'bg-success'}">${p.stockQuantity}</span>
                        </td>
                        <td class="text-end pe-4">
                            <div class="btn-group">
                                <button class="btn btn-sm btn-primary" onclick="viewProductDetail(${p.id})" title="Xem chi tiết">
                                    <i class="cil-eye"></i> <span class="d-none d-lg-inline">Xem</span>
                                </button>
                                <button class="btn btn-sm btn-info text-white" onclick="openEditModal(${p.id})" title="Sửa">
                                    <i class="cil-pencil"></i> <span class="d-none d-lg-inline">Sửa</span>
                                </button>
                                <button class="btn btn-sm btn-danger text-white" onclick="deleteProduct(${p.id})" title="Xóa">
                                    <i class="cil-trash"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                `;
            });
        } catch (e) { console.error(e); }
    }

    function openCreateModal() {
        const form = document.getElementById('productForm');
        form.reset();
        form.classList.remove('was-validated');
        document.getElementById('editId').value = '';
        document.getElementById('ProductModalLabel').innerText = "Thêm sản phẩm mới";
        new coreui.Modal(document.getElementById('ProductModal')).show();
    }

    async function openEditModal(id) {
        try {
            const response = await fetch(`${API_BASE}/Products/${id}`);
            const p = await response.json();
            
            const form = document.getElementById('productForm');
            form.classList.remove('was-validated');

            document.getElementById('editId').value = p.id;
            document.getElementById('name').value = p.name;
            document.getElementById('sku').value = p.sku;
            document.getElementById('categoryId').value = p.categoryId || '';
            document.getElementById('brandId').value = p.brandId || '';
            document.getElementById('unit').value = p.unit || '';
            document.getElementById('costPrice').value = p.costPrice;
            document.getElementById('retailPrice').value = p.retailPrice;
            document.getElementById('description').value = p.description || '';
            document.getElementById('imageUrl').value = p.imageUrl || '';
            
            document.getElementById('ProductModalLabel').innerText = "Chỉnh sửa sản phẩm";
            
            const detailModalEl = document.getElementById('ProductDetailModal');
            const detailModal = coreui.Modal.getInstance(detailModalEl);
            if (detailModal) detailModal.hide();
            
            new coreui.Modal(document.getElementById('ProductModal')).show();
        } catch (e) { console.error(e); }
    }

    async function viewProductDetail(id) {
        try {
            const response = await fetch(`${API_BASE}/Products/${id}`);
            const p = await response.json();
            
            const cat = categories.find(c => c.id === p.categoryId)?.name || '-';
            const brand = brands.find(b => b.id === p.brandId)?.name || '-';
            
            document.getElementById('detailName').innerText = p.name;
            document.getElementById('detailSKU').innerText = `SKU: ${p.sku}`;
            document.getElementById('detailCategory').innerText = cat;
            document.getElementById('detailBrand').innerText = brand;
            document.getElementById('detailCost').innerText = p.costPrice.toLocaleString() + ' đ';
            document.getElementById('detailCost').classList.add('money-text');
            document.getElementById('detailRetail').innerText = p.retailPrice.toLocaleString() + ' đ';
            document.getElementById('detailRetail').classList.add('money-text');
            document.getElementById('detailUnit').innerText = p.unit || '-';
            
            const stockEl = document.getElementById('detailStock');
            stockEl.innerText = p.stockQuantity;
            stockEl.className = `badge fs-6 mt-1 ${p.stockQuantity <= 5 ? 'bg-danger text-white' : 'bg-success text-white'}`;
            
            document.getElementById('detailDescription').innerText = p.description || 'Không có mô tả.';
            
            const imgEl = document.getElementById('detailImage');
            const noImgEl = document.getElementById('detailNoImage');
            if (p.imageUrl) {
                imgEl.src = p.imageUrl;
                imgEl.style.display = 'block';
                noImgEl.style.display = 'none';
            } else {
                imgEl.style.display = 'none';
                noImgEl.style.display = 'flex';
            }
            
            document.getElementById('detailCreatedAt').innerText = new Date(p.createdAt).toLocaleDateString('vi-VN');
            document.getElementById('detailUpdatedAt').innerText = p.updatedAt ? new Date(p.updatedAt).toLocaleDateString('vi-VN') : 'Chưa có';
            
            document.getElementById('btnEditFromDetail').onclick = () => openEditModal(p.id);
            
            new coreui.Modal(document.getElementById('ProductDetailModal')).show();
        } catch (e) { console.error(e); }
    }

    async function saveProduct(e) {
        e.preventDefault();
        const form = document.getElementById('productForm');
        
        if (!form.checkValidity()) {
            e.stopPropagation();
            form.classList.add('was-validated');
            return;
        }

        const id = document.getElementById('editId').value;
        const data = {
            name: document.getElementById('name').value,
            sku: document.getElementById('sku').value,
            categoryId: document.getElementById('categoryId').value ? parseInt(document.getElementById('categoryId').value) : null,
            brandId: document.getElementById('brandId').value ? parseInt(document.getElementById('brandId').value) : null,
            unit: document.getElementById('unit').value,
            costPrice: parseFloat(document.getElementById('costPrice').value),
            retailPrice: parseFloat(document.getElementById('retailPrice').value),
            description: document.getElementById('description').value,
            imageUrl: document.getElementById('imageUrl').value,
            stockQuantity: 0 
        };

        try {
            const url = id ? `${API_BASE}/Products/${id}` : `${API_BASE}/Products`;
            const method = id ? 'PUT' : 'POST';
            
            const response = await fetch(url, {
                method: method,
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            });

            await handleApiError(response);
            coreui.Modal.getInstance(document.getElementById('ProductModal')).hide();
            showAlert(id ? "Cập nhật sản phẩm thành công!" : "Thêm sản phẩm thành công!");
            loadProducts();
        } catch (error) { console.error(error); }
    }

    function deleteProduct(id) {
        showConfirm("Xác nhận xóa", "Bạn có chắc chắn muốn xóa sản phẩm này? Thao tác này sẽ không thể hoàn tác.", async () => {
            try {
                const response = await fetch(`${API_BASE}/Products/${id}`, { method: 'DELETE' });
                await handleApiError(response);
                showAlert("Đã xóa sản phẩm thành công!");
                loadProducts();
            } catch (error) { console.error(error); }
        });
    }

    document.getElementById('productForm').addEventListener('submit', saveProduct);
    document.addEventListener('DOMContentLoaded', init);
</script>
