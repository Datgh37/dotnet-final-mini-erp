@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2 class="mb-4">Create Purchase Order</h2>

<div class="card">
    <div class="card-body">
        <form id="purchaseOrderForm">
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label for="supplierId" class="form-label">Supplier ID</label>
                    <input type="number" class="form-control" id="supplierId" name="supplierId" required>
                </div>
                <div class="col-md-6 mb-3">
                    <label for="orderDate" class="form-label">Order Date</label>
                    <input type="date" class="form-control" id="orderDate" name="orderDate" required>
                </div>
            </div>

            <div class="mb-3">
                <label for="notes" class="form-label">Notes</label>
                <textarea class="form-control" id="notes" name="notes" rows="3"></textarea>
            </div>

            <div class="mb-3">
                <button type="submit" class="btn btn-primary">Create</button>
                <a href="/PurchaseOrders/Index" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

<script>
    function toDateInputValue(date) {
        const offset = date.getTimezoneOffset();
        const localDate = new Date(date.getTime() - (offset * 60 * 1000));
        return localDate.toISOString().split('T')[0];
    }

    document.getElementById("orderDate").value = toDateInputValue(new Date());

    document.getElementById("purchaseOrderForm").addEventListener("submit", async function (e) {
        e.preventDefault();

        const order = {
            supplierId: parseInt(document.getElementById("supplierId").value),
            orderDate: document.getElementById("orderDate").value,
            notes: document.getElementById("notes").value,
            items: []
        };

        try {
            const response = await fetch('https://localhost:7279/api/purchase-orders', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify(order)
            });

            if (response.ok) {
                alert('Purchase order created successfully!');
                window.location.href = '/PurchaseOrders/Index';
            } else {
                const error = await response.text();
                alert('Failed to create purchase order: ' + error);
            }
        } catch (error) {
            console.log(error);
            alert('Error: ' + error.message);
        }
    });
</script>