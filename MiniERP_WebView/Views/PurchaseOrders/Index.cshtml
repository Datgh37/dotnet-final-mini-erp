@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Đơn mua hàng (Nhập kho)</h2>
</div>

<!-- Filters -->
<div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-4">
                <label class="form-label small fw-bold">Trạng thái</label>
                <select class="form-select" id="filterStatus">
                    <option value="">-- Tất cả --</option>
                    <option value="PENDING">Chờ xử lý (PENDING)</option>
                    <option value="RECEIVED">Đã nhập kho (RECEIVED)</option>
                    <option value="CANCELLED">Đã hủy (CANCELLED)</option>
                </select>
            </div>
            <div class="col-md-2 d-flex align-items-end">
                <button class="btn btn-primary w-100" onclick="loadPurchaseOrders()">Lọc</button>
            </div>
        </div>
    </div>
</div>

<!-- Table -->
<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0 text-nowrap">
                <thead class="bg-body-tertiary">
                    <tr>
                        <th class="ps-4">Mã đơn</th>
                        <th>Ngày lập</th>
                        <th>Nhà cung cấp</th>
                        <th>Tổng tiền</th>
                        <th>Trạng thái</th>
                        <th class="text-end pe-4">Thao tác</th>
                    </tr>
                </thead>
                <tbody id="poTable"></tbody>
            </table>
        </div>
    </div>
</div>

<!-- PO Detail Modal -->
<div class="modal fade" id="PODetailModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Chi tiết đơn mua #<span id="modalPONumber"></span></h5>
                <button type="button" class="btn-close" data-coreui-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="row mb-4">
                    <div class="col-md-6">
                        <label class="text-body-secondary small">Nhà cung cấp:</label>
                        <div id="modalSupplier" class="fw-bold text-success"></div>
                    </div>
                    <div class="col-md-6">
                        <label class="text-muted small">Ngày lập:</label>
                        <div id="modalPODate"></div>
                    </div>
                </div>

                <h6>Danh sách sản phẩm nhập</h6>
                <table class="table table-sm table-bordered">
                    <thead class="table-light">
                        <tr>
                            <th>Sản phẩm</th>
                            <th class="text-end">Giá nhập</th>
                            <th class="text-center">Số lượng</th>
                            <th class="text-end">Thành tiền</th>
                        </tr>
                    </thead>
                    <tbody id="modalPOItemsTable"></tbody>
                    <tfoot>
                        <tr>
                            <th colspan="3" class="text-end">Tổng tiền nhập:</th>
                            <th class="text-end" id="modalPOTotal"></th>
                        </tr>
                    </tfoot>
                </table>

                <div id="actionArea" class="mt-4 text-center d-none">
                    <button class="btn btn-success px-4 me-2" onclick="receivePO()">Xác nhận nhập kho</button>
                    <button class="btn btn-outline-danger px-4" onclick="cancelPO()">Hủy đơn</button>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    let currentPOId = null;

    async function loadPurchaseOrders() {
        const status = document.getElementById('filterStatus').value;
        const params = new URLSearchParams();
        if (status) params.append('status', status);

        try {
            let url = `${API_BASE}/purchase-orders`;
            if (params.toString()) url += `?${params.toString()}`;
            const response = await fetch(url);
            if (!response.ok) return;
            const data = await response.json();

            window.renderTable('poTable', data, o => {
                const date = new Date(o.orderDate).toLocaleDateString('vi-VN');
                const total = o.totalAmount.toLocaleString('vi-VN');
                let badgeClass = 'bg-secondary';
                if(o.status === 'PENDING') badgeClass = 'bg-warning';
                else if(o.status === 'RECEIVED') badgeClass = 'bg-success';
                else if(o.status === 'CANCELLED') badgeClass = 'bg-danger';

                return `
                    <tr>
                        <td class="ps-4 fw-bold">PO-${o.id}</td>
                        <td>${date}</td>
                        <td class="text-success fw-semibold">${o.supplierName || 'NCC ID: ' + o.supplierId}</td>
                        <td class="fw-bold">${total} đ</td>
                        <td><span class="badge ${badgeClass}">${o.status}</span></td>
                        <td class="text-end pe-4">
                            <button class="btn btn-sm btn-outline-primary" onclick="viewPODetails(${o.id})">Chi tiết</button>
                        </td>
                    </tr>
                `;
            });
        } catch (e) { console.error(e); }
    }

    async function viewPODetails(id) {
        currentPOId = id;
        try {
            const response = await fetch(`${API_BASE}/purchase-orders/${id}`);
            const o = await response.json();

            document.getElementById('modalPONumber').innerText = o.id;
            document.getElementById('modalSupplier').innerText = o.supplierName || 'NCC ID: ' + o.supplierId;
            document.getElementById('modalPODate').innerText = new Date(o.orderDate).toLocaleString('vi-VN');
            document.getElementById('modalPOTotal').innerText = o.totalAmount.toLocaleString('vi-VN') + ' đ';

            let itemsHtml = '';
            o.items.forEach(item => {
                itemsHtml += `
                    <tr>
                        <td>${item.productName || 'ID: ' + item.productId}</td>
                        <td class="text-end">${item.unitPrice.toLocaleString()}</td>
                        <td class="text-center">${item.quantity}</td>
                        <td class="text-end">${(item.unitPrice * item.quantity).toLocaleString()}</td>
                    </tr>
                `;
            });
            document.getElementById('modalPOItemsTable').innerHTML = itemsHtml;

            const actionArea = document.getElementById('actionArea');
            if(o.status === 'PENDING') {
                actionArea.classList.remove('d-none');
            } else {
                actionArea.classList.add('d-none');
            }

            new coreui.Modal(document.getElementById('PODetailModal')).show();
        } catch (e) { console.error(e); }
    }

    async function receivePO() {
        if(!confirm("Xác nhận nhập kho các sản phẩm này?")) return;
        const user = JSON.parse(localStorage.getItem('user') || '{}');
        const userId = user.id || 1;

        try {
            const response = await fetch(`${API_BASE}/purchase-orders/${currentPOId}/receive?receivedBy=${userId}`, {
                method: 'PATCH'
            });
            await handleApiError(response);
            coreui.Modal.getInstance(document.getElementById('PODetailModal')).hide();
            showAlert("Đã nhập kho thành công!");
            loadPurchaseOrders();
        } catch (e) { console.error(e); }
    }

    async function cancelPO() {
        if(!confirm("Xác nhận hủy đơn mua hàng này?")) return;
        try {
            const response = await fetch(`${API_BASE}/purchase-orders/${currentPOId}/cancel`, {
                method: 'PATCH'
            });
            await handleApiError(response);
            coreui.Modal.getInstance(document.getElementById('PODetailModal')).hide();
            showAlert("Đã hủy đơn mua hàng.");
            loadPurchaseOrders();
        } catch (e) { console.error(e); }
    }

    document.addEventListener('DOMContentLoaded', loadPurchaseOrders);
</script>
