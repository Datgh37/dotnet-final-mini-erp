@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2 class="mb-4">Purchase Orders</h2>

<div class="card mb-3">
    <div class="card-body">
        <button type="button" class="btn btn-primary mb-3" data-coreui-toggle="modal" data-coreui-target="#AddPurchaseOrderModal">
            Create New Order
        </button>

        <!-- Add Modal -->
        <div class="modal fade" id="AddPurchaseOrderModal" tabindex="-1" aria-labelledby="AddPurchaseOrderModalLabel" aria-hidden="true">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title" id="AddPurchaseOrderModalLabel">Create Purchase Order</h5>
                        <button type="button" class="btn-close" data-coreui-dismiss="modal" aria-label="Close"></button>
                    </div>

                    <div class="modal-body">
                        <form id="addPurchaseOrderForm">
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label for="addSupplierId" class="form-label">Supplier ID</label>
                                    <input type="number" class="form-control" id="addSupplierId" required>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label for="addOrderDate" class="form-label">Order Date</label>
                                    <input type="date" class="form-control" id="addOrderDate" required>
                                </div>
                            </div>

                            <div class="mb-3">
                                <label for="addNotes" class="form-label">Notes</label>
                                <textarea class="form-control" id="addNotes" rows="3"></textarea>
                            </div>
                        </form>
                    </div>

                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-coreui-dismiss="modal">Close</button>
                        <button type="submit" class="btn btn-primary" form="addPurchaseOrderForm">Save</button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Edit Modal -->
        <div class="modal fade" id="EditPurchaseOrderModal" tabindex="-1" aria-labelledby="EditPurchaseOrderModalLabel" aria-hidden="true">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title" id="EditPurchaseOrderModalLabel">Edit Purchase Order</h5>
                        <button type="button" class="btn-close" data-coreui-dismiss="modal" aria-label="Close"></button>
                    </div>

                    <div class="modal-body">
                        <form id="editPurchaseOrderForm">
                            <div class="mb-3">
                                <label for="editId" class="form-label">Order ID</label>
                                <input type="number" class="form-control" id="editId" readonly>
                            </div>

                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label for="editSupplierId" class="form-label">Supplier ID</label>
                                    <input type="number" class="form-control" id="editSupplierId" required>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label for="editOrderDate" class="form-label">Order Date</label>
                                    <input type="date" class="form-control" id="editOrderDate" required>
                                </div>
                            </div>

                            <div class="mb-3">
                                <label for="editStatus" class="form-label">Status</label>
                                <input type="text" class="form-control" id="editStatus" readonly>
                            </div>

                            <div class="mb-3">
                                <label for="editNotes" class="form-label">Notes</label>
                                <textarea class="form-control" id="editNotes" rows="3"></textarea>
                            </div>
                        </form>
                    </div>

                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-coreui-dismiss="modal">Close</button>
                        <button type="submit" class="btn btn-primary" form="editPurchaseOrderForm">Save</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <table class="table table-bordered table-hover">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Supplier ID</th>
                    <th>Order Date</th>
                    <th>Status</th>
                    <th width="200">Actions</th>
                </tr>
            </thead>
            <tbody id="purchaseOrderTable"></tbody>
        </table>
    </div>
</div>

<script>
    let selectedPurchaseOrderId = null;
    let currentItems = [];

    function toDateInputValue(date) {
        const offset = date.getTimezoneOffset();
        const localDate = new Date(date.getTime() - (offset * 60 * 1000));
        return localDate.toISOString().split('T')[0];
    }

    function getStatusClass(status) {
        switch ((status || '').toLowerCase()) {
            case 'received':
                return 'bg-success';
            case 'cancelled':
                return 'bg-danger';
            case 'pending':
            default:
                return 'bg-info';
        }
    }

    async function loadPurchaseOrders() {
        try {
            const response = await fetch('https://localhost:7279/api/purchase-orders');
            const orders = await response.json();

            let html = "";
            orders.forEach(order => {
                const orderDate = order.orderDate ? new Date(order.orderDate).toLocaleDateString('en-US') : '';
                const statusClass = getStatusClass(order.status);

                html += `
                    <tr>
                        <td>${order.id ?? ''}</td>
                        <td>${order.supplierId ?? ''}</td>
                        <td>${orderDate}</td>
                        <td><span class="badge ${statusClass}">${order.status || 'Pending'}</span></td>
                        <td>
                            <button
                                type="button"
                                class="btn btn-sm btn-warning btn-edit"
                                data-id="${order.id}"
                                data-coreui-toggle="modal"
                                data-coreui-target="#EditPurchaseOrderModal">
                                Edit
                            </button>
                            <button type="button" class="btn btn-sm btn-success" onclick="receiveOrder(${order.id})">Receive</button>
                            <button type="button" class="btn btn-sm btn-danger" onclick="cancelOrder(${order.id})">Cancel</button>
                        </td>
                    </tr>
                `;
            });

            document.getElementById("purchaseOrderTable").innerHTML = html;
        }
        catch (error) {
            console.log(error);
            alert("Load purchase orders failed");
        }
    }

    document.addEventListener("click", async function (e) {
        const editButton = e.target.closest(".btn-edit");
        if (!editButton) return;

        const orderId = editButton.dataset.id;
        selectedPurchaseOrderId = orderId;

        try {
            const response = await fetch(`https://localhost:7279/api/purchase-orders/${orderId}`);
            if (!response.ok) {
                alert("Load order detail failed");
                return;
            }

            const order = await response.json();
            currentItems = order.items || [];

            document.getElementById("editId").value = order.id ?? "";
            document.getElementById("editSupplierId").value = order.supplierId ?? "";
            document.getElementById("editOrderDate").value = order.orderDate ? order.orderDate.split('T')[0] : "";
            document.getElementById("editStatus").value = order.status ?? "";
            document.getElementById("editNotes").value = order.notes ?? "";
        } catch (error) {
            console.log(error);
            alert("Load order detail failed");
        }
    });

    document.getElementById("addPurchaseOrderForm").addEventListener("submit", async function (e) {
        e.preventDefault();

        const order = {
            supplierId: parseInt(document.getElementById("addSupplierId").value),
            orderDate: document.getElementById("addOrderDate").value,
            notes: document.getElementById("addNotes").value,
            items: []
        };

        try {
            const response = await fetch('https://localhost:7279/api/purchase-orders', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify(order)
            });

            if (response.ok) {
                const modalEl = document.getElementById("AddPurchaseOrderModal");
                const modal = coreui.Modal.getOrCreateInstance(modalEl);
                modal.hide();

                document.getElementById("addPurchaseOrderForm").reset();
                document.getElementById("addOrderDate").value = toDateInputValue(new Date());

                await loadPurchaseOrders();
                alert('Purchase order created successfully!');
            } else {
                const error = await response.text();
                alert('Failed to create purchase order: ' + (error || response.statusText));
            }
        } catch (error) {
            console.log(error);
            alert('Error: ' + error.message);
        }
    });

    document.getElementById("editPurchaseOrderForm").addEventListener("submit", async function (e) {
        e.preventDefault();

        if (!selectedPurchaseOrderId) {
            alert("No order selected");
            return;
        }

        const order = {
            id: parseInt(document.getElementById("editId").value),
            supplierId: parseInt(document.getElementById("editSupplierId").value),
            orderDate: document.getElementById("editOrderDate").value,
            status: document.getElementById("editStatus").value,
            notes: document.getElementById("editNotes").value,
            items: currentItems
        };

        try {
            const response = await fetch(`https://localhost:7279/api/purchase-orders/${selectedPurchaseOrderId}`, {
                method: 'PUT',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify(order)
            });

            if (response.ok) {
                const modalEl = document.getElementById("EditPurchaseOrderModal");
                const modal = coreui.Modal.getOrCreateInstance(modalEl);
                modal.hide();

                selectedPurchaseOrderId = null;
                currentItems = [];

                await loadPurchaseOrders();
                alert('Purchase order updated successfully!');
            } else {
                const error = await response.text();
                alert('Failed to update purchase order: ' + (error || response.statusText));
            }
        } catch (error) {
            console.log(error);
            alert('Error: ' + error.message);
        }
    });

    async function receiveOrder(id) {
        if (confirm('Confirm receiving this order?')) {
            try {
                const response = await fetch(`https://localhost:7279/api/purchase-orders/${id}/receive?receivedBy=1`, {
                    method: 'PATCH'
                });

                if (response.ok) {
                    alert('Order received successfully!');
                    await loadPurchaseOrders();
                } else {
                    alert('Failed to receive order');
                }
            } catch (error) {
                console.log(error);
                alert('Error: ' + error.message);
            }
        }
    }

    async function cancelOrder(id) {
        if (confirm('Cancel this order?')) {
            try {
                const response = await fetch(`https://localhost:7279/api/purchase-orders/${id}/cancel`, {
                    method: 'PATCH'
                });

                if (response.ok) {
                    alert('Order cancelled successfully!');
                    await loadPurchaseOrders();
                } else {
                    alert('Failed to cancel order');
                }
            } catch (error) {
                console.log(error);
                alert('Error: ' + error.message);
            }
        }
    }

    document.getElementById("addOrderDate").value = toDateInputValue(new Date());
    loadPurchaseOrders();
</script>