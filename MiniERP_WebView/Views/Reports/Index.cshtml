@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2 class="mb-4">Reports & Analytics</h2>

<div class="row">
    <div class="col-md-8">
        <div class="card mb-4">
            <div class="card-header">
                <strong>Revenue Trend</strong>
                <div class="float-end">
                    <input type="date" id="reportFrom" class="form-control form-control-sm d-inline-block w-auto">
                    <input type="date" id="reportTo" class="form-control form-control-sm d-inline-block w-auto">
                    <button class="btn btn-sm btn-primary" onclick="loadRevenueChart()">Filter</button>
                </div>
            </div>
            <div class="card-body">
                <div class="c-chart-wrapper" style="height:300px;">
                    <canvas id="revenueChart"></canvas>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card mb-4">
            <div class="card-header"><strong>Top Selling Products</strong></div>
            <div class="card-body p-0">
                <table class="table table-sm mb-0">
                    <thead>
                        <tr>
                            <th>Product</th>
                            <th class="text-end">Sold</th>
                        </tr>
                    </thead>
                    <tbody id="topSellingTable"></tbody>
                </table>
            </div>
        </div>
        
        <div class="card mb-4">
            <div class="card-header text-white bg-danger"><strong>Low Stock Alert</strong></div>
            <div class="card-body p-0">
                <table class="table table-sm mb-0">
                    <thead>
                        <tr>
                            <th>Product</th>
                            <th class="text-end">Qty</th>
                        </tr>
                    </thead>
                    <tbody id="lowStockTable"></tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<script src="~/vendors/@@coreui/chartjs/js/coreui-chartjs.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
    let revenueChart = null;

    async function loadRevenueChart() {
        const from = document.getElementById('reportFrom').value;
        const to = document.getElementById('reportTo').value;
        
        try {
            const response = await fetch(`${API_BASE}/Reports/revenue?from=${from}&to=${to}`);
            const data = await response.json();
            
            const labels = data.map(i => new Date(i.orderDate).toLocaleDateString());
            const values = data.map(i => i.dailyRevenue);

            if (revenueChart) revenueChart.destroy();

            const ctx = document.getElementById('revenueChart').getContext('2d');
            revenueChart = new Chart(ctx, {
                type: 'line',
                data: {
                    labels: labels,
                    datasets: [{
                        label: 'Daily Revenue (VND)',
                        backgroundColor: 'rgba(0, 0, 255, 0.1)',
                        borderColor: 'rgba(0, 0, 255, 0.8)',
                        pointBackgroundColor: 'rgba(0, 0, 255, 1)',
                        data: values,
                        fill: true
                    }]
                },
                options: {
                    maintainAspectRatio: false,
                    scales: {
                        y: { beginAtZero: true }
                    }
                }
            });
        } catch (error) { console.error(error); }
    }

    async function loadTopSelling() {
        try {
            const response = await fetch(`${API_BASE}/Reports/top-selling?top=5`);
            const data = await response.json();
            document.getElementById('topSellingTable').innerHTML = data.map(i => `
                <tr>
                    <td>${i.name}</td>
                    <td class="text-end fw-bold">${i.totalSold}</td>
                </tr>
            `).join('');
        } catch (error) { console.error(error); }
    }

    async function loadLowStock() {
        try {
            const response = await fetch(`${API_BASE}/Reports/low-stock?threshold=20`);
            const data = await response.json();
            document.getElementById('lowStockTable').innerHTML = data.map(i => `
                <tr>
                    <td>${i.name}</td>
                    <td class="text-end text-danger fw-bold">${i.stockQuantity}</td>
                </tr>
            `).join('');
        } catch (error) { console.error(error); }
    }

    // Default dates: last 30 days
    const end = new Date();
    const start = new Date();
    start.setDate(end.getDate() - 30);
    document.getElementById('reportFrom').value = start.toISOString().split('T')[0];
    document.getElementById('reportTo').value = end.toISOString().split('T')[0];

    loadRevenueChart();
    loadTopSelling();
    loadLowStock();
</script>