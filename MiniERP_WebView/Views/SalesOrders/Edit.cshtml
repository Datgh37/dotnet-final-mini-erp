@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2 class="mb-4">Edit Sales Order</h2>
<div class="card">
    <div class="card-body">
        <form id="salesOrderForm">
            <div class="mb-3">
                <label for="id" class="form-label">Order ID</label>
                <input type="number" class="form-control" id="id" name="id" readonly>
            </div>
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label for="customerId" class="form-label">Customer ID</label>
                    <input type="number" class="form-control" id="customerId" name="customerId" required>
                </div>
                <div class="col-md-6 mb-3">
                    <label for="orderDate" class="form-label">Order Date</label>
                    <input type="date" class="form-control" id="orderDate" name="orderDate" required>
                </div>
            </div>
            <div class="mb-3">
                <label for="status" class="form-label">Status</label>
                <input type="text" class="form-control" id="status" name="status" readonly>
            </div>
            <div class="mb-3">
                <label for="totalAmount" class="form-label">Total Amount</label>
                <input type="number" step="0.01" class="form-control" id="totalAmount" name="totalAmount" readonly>
            </div>
            <div class="mb-3">
                <label for="notes" class="form-label">Notes</label>
                <textarea class="form-control" id="notes" name="notes" rows="3"></textarea>
            </div>
            <div class="mb-3">
                <button type="submit" class="btn btn-primary">Update</button>
                <a href="/SalesOrders/Index" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

<script>
    const orderId = new URLSearchParams(window.location.search).get('id');

    async function loadOrder() {
        try {
            const response = await fetch(`${window.API_BASE}/sales-orders/${orderId}`);
            const order = await response.json();

            document.getElementById("id").value = order.id;
            document.getElementById("customerId").value = order.customerId;
            document.getElementById("orderDate").value = order.orderDate.split('T')[0];
            document.getElementById("status").value = order.status;
            document.getElementById("totalAmount").value = order.totalAmount;
            document.getElementById("notes").value = order.notes;
        } catch (error) {
            console.log(error);
            alert("Load order failed");
        }
    }

    document.getElementById("salesOrderForm").addEventListener("submit", async function (e) {
        e.preventDefault();

        const order = {
            id: parseInt(document.getElementById("id").value),
            customerId: parseInt(document.getElementById("customerId").value),
            orderDate: document.getElementById("orderDate").value,
            status: document.getElementById("status").value,
            totalAmount: parseFloat(document.getElementById("totalAmount").value),
            notes: document.getElementById("notes").value
        };

        try {
            const response = await fetch(`${window.API_BASE}/sales-orders/${orderId}`, {
                method: 'PUT',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify(order)
            });

            if (response.ok) {
                alert('Sales order updated successfully!');
                window.location.href = '/SalesOrders/Index';
            } else {
                alert('Failed to update sales order');
            }
        } catch (error) {
            console.log(error);
            alert('Error: ' + error.message);
        }
    });

    loadOrder();
</script>

