@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Quản lý Đơn bán hàng</h2>
</div>

<!-- Filters -->
<div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-3">
                <label class="form-label small fw-bold">Trạng thái</label>
                <select class="form-select" id="filterStatus">
                    <option value="">-- Tất cả --</option>
                    <option value="NEW">Mới (NEW)</option>
                    <option value="PROCESSING">Đang xử lý (PROCESSING)</option>
                    <option value="SHIPPED">Đang giao (SHIPPED)</option>
                    <option value="COMPLETED">Hoàn thành (COMPLETED)</option>
                    <option value="CANCELLED">Đã hủy (CANCELLED)</option>
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label small fw-bold">Khách hàng</label>
                <select class="form-select" id="filterCustomer"></select>
            </div>
            <div class="col-md-2">
                <label class="form-label small fw-bold">Từ ngày</label>
                <input type="date" class="form-control" id="filterFrom">
            </div>
            <div class="col-md-2">
                <label class="form-label small fw-bold">Đến ngày</label>
                <input type="date" class="form-control" id="filterTo">
            </div>
            <div class="col-md-2 d-flex align-items-end">
                <button class="btn btn-primary w-100" onclick="loadOrders()">Lọc</button>
            </div>
        </div>
    </div>
</div>

<!-- Table -->
<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0 text-nowrap">
                <thead class="bg-body-tertiary">
                    <tr>
                        <th class="ps-4">Mã đơn</th>
                        <th>Ngày đặt</th>
                        <th>Khách hàng</th>
                        <th>Tổng tiền</th>
                        <th>Trạng thái</th>
                        <th class="text-end pe-4">Thao tác</th>
                    </tr>
                </thead>
                <tbody id="orderTable"></tbody>
            </table>
        </div>
    </div>
</div>

<!-- Order Detail & Status Modal -->
<div class="modal fade" id="OrderDetailModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Chi tiết đơn hàng <span id="modalOrderNumber"></span></h5>
                <button type="button" class="btn-close" data-coreui-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="row mb-4">
                    <div class="col-md-6">
                        <label class="text-body-secondary small">Khách hàng:</label>
                        <div id="modalCustomer" class="fw-bold"></div>
                        <label class="text-muted small mt-2">Địa chỉ giao hàng:</label>
                        <div id="modalAddress"></div>
                    </div>
                    <div class="col-md-6">
                        <label class="text-muted small">Ngày đặt:</label>
                        <div id="modalDate"></div>
                        <label class="text-muted small mt-2">Ghi chú:</label>
                        <div id="modalNotes"></div>
                    </div>
                </div>

                <h6>Danh sách sản phẩm</h6>
                <table class="table table-sm table-bordered">
                    <thead class="table-light">
                        <tr>
                            <th>Sản phẩm</th>
                            <th class="text-end">Đơn giá</th>
                            <th class="text-center">SL</th>
                            <th class="text-end">Thành tiền</th>
                        </tr>
                    </thead>
                    <tbody id="modalItemsTable"></tbody>
                    <tfoot>
                        <tr>
                            <th colspan="3" class="text-end">Tổng cộng:</th>
                            <th class="text-end" id="modalTotal"></th>
                        </tr>
                    </tfoot>
                </table>

                <hr>
                <div class="bg-body-tertiary p-3 rounded">
                    <label class="form-label fw-bold">Cập nhật trạng thái</label>
                    <div class="d-flex gap-2">
                        <select class="form-select w-50" id="updateStatusSelect">
                            <option value="NEW">NEW</option>
                            <option value="PROCESSING">PROCESSING</option>
                            <option value="SHIPPED">SHIPPED</option>
                            <option value="COMPLETED">COMPLETED</option>
                            <option value="CANCELLED">CANCELLED</option>
                        </select>
                        <button class="btn btn-success" onclick="updateOrderStatus()">Cập nhật</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    let currentOrderId = null;

    async function init() {
        await populateSelect('filterCustomer', 'Customers', '-- Tất cả khách hàng --');
        loadOrders();
    }

    async function loadOrders() {
        const status = document.getElementById('filterStatus').value;
        const customerId = document.getElementById('filterCustomer').value;
        const from = document.getElementById('filterFrom').value;
        const to = document.getElementById('filterTo').value;

        const params = new URLSearchParams();
        if (status) params.append('status', status);
        if (customerId) params.append('customerId', customerId);
        if (from) params.append('fromDate', from);
        if (to) params.append('toDate', to);

        try {
            let url = `${API_BASE}/sales-orders`;
            if (params.toString()) url += `?${params.toString()}`;
            const response = await fetch(url);
            if (!response.ok) return;
            const data = await response.json();

            window.renderTable('orderTable', data, o => {
                const date = new Date(o.orderDate).toLocaleDateString('vi-VN');
                const total = o.totalAmount.toLocaleString('vi-VN');
                let badgeClass = 'bg-secondary';
                if(o.status === 'NEW') badgeClass = 'bg-info';
                else if(o.status === 'PROCESSING') badgeClass = 'bg-warning';
                else if(o.status === 'SHIPPED') badgeClass = 'bg-primary';
                else if(o.status === 'COMPLETED') badgeClass = 'bg-success';
                else if(o.status === 'CANCELLED') badgeClass = 'bg-danger';

                return `
                    <tr>
                        <td class="ps-4 fw-bold">#${o.orderNumber}</td>
                        <td>${date}</td>
                        <td>${o.customerName || 'Khách lẻ'}</td>
                        <td class="fw-bold">${total} đ</td>
                        <td><span class="badge ${badgeClass}">${o.status}</span></td>
                        <td class="text-end pe-4">
                            <button class="btn btn-sm btn-outline-primary" onclick="viewOrderDetails(${o.id})">Chi tiết & Trạng thái</button>
                        </td>
                    </tr>
                `;
            });
        } catch (e) { console.error(e); }
    }

    async function viewOrderDetails(id) {
        currentOrderId = id;
        try {
            const response = await fetch(`${API_BASE}/sales-orders/${id}`);
            const o = await response.json();

            document.getElementById('modalOrderNumber').innerText = o.orderNumber;
            document.getElementById('modalCustomer').innerText = o.customerName || 'Khách lẻ';
            document.getElementById('modalAddress').innerText = o.shippingAddress || '-';
            document.getElementById('modalDate').innerText = new Date(o.orderDate).toLocaleString('vi-VN');
            document.getElementById('modalNotes').innerText = o.notes || '-';
            document.getElementById('modalTotal').innerText = o.totalAmount.toLocaleString('vi-VN') + ' đ';
            document.getElementById('updateStatusSelect').value = o.status;

            let itemsHtml = '';
            o.items.forEach(item => {
                itemsHtml += `
                    <tr>
                        <td>${item.productName || 'ID: ' + item.productId}</td>
                        <td class="text-end">${item.unitPrice.toLocaleString()}</td>
                        <td class="text-center">${item.quantity}</td>
                        <td class="text-end">${(item.unitPrice * item.quantity).toLocaleString()}</td>
                    </tr>
                `;
            });
            document.getElementById('modalItemsTable').innerHTML = itemsHtml;

            new coreui.Modal(document.getElementById('OrderDetailModal')).show();
        } catch (e) { console.error(e); }
    }

    async function updateOrderStatus() {
        const newStatus = document.getElementById('updateStatusSelect').value;
        try {
            const response = await fetch(`${API_BASE}/sales-orders/${currentOrderId}/status`, {
                method: 'PATCH',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ status: newStatus })
            });

            await handleApiError(response);
            coreui.Modal.getInstance(document.getElementById('OrderDetailModal')).hide();
            showAlert("Cập nhật trạng thái đơn hàng thành công!");
            loadOrders();
        } catch (e) { console.error(e); }
    }

    document.addEventListener('DOMContentLoaded', init);
</script>
