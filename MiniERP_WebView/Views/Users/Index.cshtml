@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Quản trị Người dùng</h2>
    <button class="btn btn-primary" onclick="openCreateModal()">Thêm tài khoản</button>
</div>

<!-- Users Table -->
<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0 text-nowrap">
                <thead class="bg-body-tertiary">
                    <tr>
                        <th class="ps-4">Username</th>
                        <th>Họ và tên</th>
                        <th>Email</th>
                        <th>Vai trò</th>
                        <th class="text-end pe-4">Thao tác</th>
                    </tr>
                </thead>
                <tbody id="userTable"></tbody>
            </table>
        </div>
    </div>
</div>

<!-- User Detail Modal -->
<div class="modal fade" id="UserDetailModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-body-tertiary">
                <h5 class="modal-title">Hồ sơ người dùng</h5>
                <button type="button" class="btn-close" data-coreui-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="text-center mb-4">
                    <div class="avatar avatar-xl bg-primary text-white d-inline-flex align-items-center justify-content-center rounded-circle mb-2 fs-1" id="detailAvatar" style="width: 80px; height: 80px;"></div>
                    <h3 id="detailFullNameDisplay" class="mb-0"></h3>
                    <div id="detailUserNameDisplay" class="text-body-secondary fw-bold"></div>
                </div>
                
                <div class="card border-0 bg-body-tertiary rounded-3 mb-3">
                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-6">
                                <label class="text-body-secondary small d-block text-uppercase mb-1">Vai trò</label>
                                <div id="detailRole" class="badge bg-primary fs-6"></div>
                            </div>
                            <div class="col-6">
                                <label class="text-body-secondary small d-block text-uppercase mb-1">ID Hệ thống</label>
                                <div id="detailId" class="fw-bold"></div>
                            </div>
                            <div class="col-12">
                                <label class="text-body-secondary small d-block text-uppercase mb-1">Địa chỉ Email</label>
                                <div id="detailEmail" class="fw-semibold"></div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer bg-body-tertiary">
                <button type="button" class="btn btn-secondary" data-coreui-dismiss="modal">Đóng</button>
                <button type="button" class="btn btn-info text-white" id="btnEditFromDetail">Sửa hồ sơ</button>
            </div>
        </div>
    </div>
</div>

<!-- User Create/Edit Modal -->
<div class="modal fade" id="UserModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <form id="userForm" class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="UserModalLabel">Người dùng</h5>
                <button type="button" class="btn-close" data-coreui-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="editUserId">
                <div class="mb-3">
                    <label class="form-label">Tên đăng nhập <span class="text-danger">*</span></label>
                    <input type="text" class="form-control" id="userName" required>
                </div>
                <div id="passwordArea">
                    <div class="mb-3">
                        <label class="form-label">Mật khẩu <span class="text-danger">*</span></label>
                        <input type="password" class="form-control" id="password" required>
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label">Họ và tên</label>
                    <input type="text" class="form-control" id="fullName">
                </div>
                <div class="mb-3">
                    <label class="form-label">Email</label>
                    <input type="email" class="form-control" id="email">
                </div>
                <div class="mb-3">
                    <label class="form-label">Vai trò</label>
                    <select class="form-select" id="roleId"></select>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-coreui-dismiss="modal">Hủy</button>
                <button type="submit" class="btn btn-primary">Lưu</button>
            </div>
        </form>
    </div>
</div>

<script>
    async function init() {
        await populateSelect('roleId', 'Roles', '-- Chọn vai trò --');
        loadUsers();
    }

    async function loadUsers() {
        try {
            const response = await fetch(`${API_BASE}/Users`);
            if (!response.ok) return;
            const data = await response.json();

            window.renderTable('userTable', data, u => `
                <tr>
                    <td class="ps-4">
                        <div class="fw-bold text-primary">${u.userName}</div>
                        <div class="small text-body-secondary">ID: ${u.id}</div>
                    </td>
                    <td>${u.fullName || '-'}</td>
                    <td>${u.email || '-'}</td>
                    <td><span class="badge bg-body-tertiary text-primary border border-primary">${u.role || 'User'}</span></td>
                    <td class="text-end pe-4">
                        <div class="btn-group">
                            <button class="btn btn-sm btn-primary" onclick="viewUserDetail(${u.id})" title="Xem hồ sơ">
                                <i class="cil-eye"></i> <span class="d-none d-lg-inline">Xem</span>
                            </button>
                            <button class="btn btn-sm btn-info text-white" onclick="openEditModal(${u.id})" title="Sửa">
                                <i class="cil-pencil"></i> <span class="d-none d-lg-inline">Sửa</span>
                            </button>
                            <button class="btn btn-sm btn-danger text-white" onclick="deleteUser(${u.id})" title="Xóa">
                                <i class="cil-trash"></i>
                            </button>
                        </div>
                    </td>
                </tr>
            `);
        } catch (e) { console.error(e); }
    }

    function openCreateModal() {
        const form = document.getElementById('userForm');
        form.reset();
        form.classList.remove('was-validated');
        document.getElementById('editUserId').value = '';
        document.getElementById('passwordArea').style.display = 'block';
        document.getElementById('password').required = true;
        document.getElementById('userName').disabled = false;
        document.getElementById('UserModalLabel').innerText = "Tạo người dùng mới";
        new coreui.Modal(document.getElementById('UserModal')).show();
    }

    async function openEditModal(id) {
        try {
            const response = await fetch(`${API_BASE}/Users/${id}`);
            const u = await response.json();
            
            const form = document.getElementById('userForm');
            form.classList.remove('was-validated');

            document.getElementById('editUserId').value = u.id;
            document.getElementById('userName').value = u.userName;
            document.getElementById('userName').disabled = true;
            document.getElementById('fullName').value = u.fullName || '';
            document.getElementById('email').value = u.email || '';
            document.getElementById('roleId').value = u.roleId || '';
            
            document.getElementById('passwordArea').style.display = 'none';
            document.getElementById('password').required = false;
            
            document.getElementById('UserModalLabel').innerText = "Chỉnh sửa người dùng";
            
            const detailModalEl = document.getElementById('UserDetailModal');
            const detailModal = coreui.Modal.getInstance(detailModalEl);
            if (detailModal) detailModal.hide();

            new coreui.Modal(document.getElementById('UserModal')).show();
        } catch (e) { console.error(e); }
    }

    async function viewUserDetail(id) {
        try {
            const response = await fetch(`${API_BASE}/Users/${id}`);
            const u = await response.json();
            
            document.getElementById('detailFullNameDisplay').innerText = u.fullName || 'N/A';
            document.getElementById('detailUserNameDisplay').innerText = '@@' + u.userName;
            document.getElementById('detailId').innerText = u.id;
            document.getElementById('detailEmail').innerText = u.email || 'Chưa cập nhật';
            document.getElementById('detailRole').innerText = u.role || 'User';
            
            const initials = (u.fullName || u.userName).split(' ').map(n => n[0]).join('').toUpperCase().substring(0, 2);
            document.getElementById('detailAvatar').innerText = initials;
            
            document.getElementById('btnEditFromDetail').onclick = () => openEditModal(u.id);
            
            new coreui.Modal(document.getElementById('UserDetailModal')).show();
        } catch (e) { console.error(e); }
    }

    async function handleUserSubmit(e) {
        e.preventDefault();
        const form = document.getElementById('userForm');
        
        if (!form.checkValidity()) {
            e.stopPropagation();
            form.classList.add('was-validated');
            return;
        }

        const id = document.getElementById('editUserId').value;
        
        let url = `${API_BASE}/Users`;
        let method = 'POST';
        let data = {
            fullName: document.getElementById('fullName').value,
            email: document.getElementById('email').value,
            roleId: parseInt(document.getElementById('roleId').value) || null
        };

        if (id) {
            url += `/${id}`;
            method = 'PUT';
            data.id = parseInt(id);
        } else {
            data.userName = document.getElementById('userName').value;
            data.password = document.getElementById('password').value;
        }

        try {
            const response = await fetch(url, {
                method: method,
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            });

            await handleApiError(response);
            coreui.Modal.getInstance(document.getElementById('UserModal')).hide();
            showAlert(id ? "Cập nhật người dùng thành công!" : "Tạo người dùng mới thành công!");
            loadUsers();
        } catch (e) { console.error(e); }
    }

    async function deleteUser(id) {
        const currentUser = JSON.parse(localStorage.getItem('user') || '{}');
        if (currentUser.id == id) {
            showAlert("Bạn không thể xóa tài khoản của chính mình!", "danger");
            return;
        }

        if(!confirm("Xóa tài khoản này?")) return;
        try {
            const response = await fetch(`${API_BASE}/Users/${id}`, { method: 'DELETE' });
            await handleApiError(response);
            showAlert("Đã xóa tài khoản!");
            loadUsers();
        } catch (e) { console.error(e); }
    }

    document.getElementById('userForm').addEventListener('submit', handleUserSubmit);
    document.addEventListener('DOMContentLoaded', init);
</script>
